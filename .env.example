# 阿里云 DNS DDNS 配置
# 获取密钥: https://ram.console.aliyun.com/manage/ak
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# 域名列表，逗号分隔
DDNS_DOMAINS=example.com,api.example.com

# 服务器公网出口网卡
DDNS_NETWORK_INTERFACE=eth0

# Let's Encrypt 配置
ACME_EMAIL=admin@example.com
ACME_DNS_PROVIDER=alidns

# SSL 证书存储路径
SSL_CERT_DIR=/etc/nginx/ssl

# Nginx 配置路径
NGINX_CONF_DIR=/etc/nginx/conf.d
NGINX_BIN=/usr/sbin/nginx

# PushPlus 通知 Token
PUSHPLUS_TOKEN=your_pushplus_token_here

# 服务端口
SERVER_PORT=3456

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=server_panel

# Session 密钥 (务必修改为随机字符串)
SESSION_SECRET=change-me-to-random-string

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 启用模块
MODULE_DDNS=true
MODULE_SSL=true
MODULE_NGINX=true
MODULE_PROXY=true
MODULE_PORT=true

# 管理员账号
ADMIN_USER=admin
ADMIN_PASS=admin123
